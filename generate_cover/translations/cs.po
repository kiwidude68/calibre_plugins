msgstr "Generovat && uložit"

#: dialogs.py:159
msgid "Generate cover using these settings and save for future usage"
msgstr ""
"Vygenerovat obálku s těmito nastaveními a uložit je pro budoucí použití"

#: dialogs.py:161
msgid "Generate && Revert"
msgstr "Generovat && zahodit změny"

#: dialogs.py:162
msgid "Generate cover using these settings then discard them"
msgstr "Vygenerovat obálku s těmito nastaveními a potom je zahodit"

