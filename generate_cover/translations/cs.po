#: dialogs.py:878
msgid "Cannot copy"
msgstr "Nelze kopírovat"

#: dialogs.py:892
msgid "Overwrite existing"
msgstr "Přepsat existující"

#: dialogs.py:893
msgid ""
"An image file already exists with this name. Do you want to overwrite it?"
msgstr "Soubor obrázku s tímto názvem už existuje. Chcete ho přepsat?"

#: dialogs.py:896
msgid "Enter image name"
msgstr "Zadejte název obrázku"

#: dialogs.py:897
msgid "Enter a unique name for this image:"
msgstr "Zadejte jedinečný název tohoto obrázku:"

#: dialogs.py:911
msgid "You do not have permission to overwrite the file"
msgstr "Nemáte oprávnění k přepsání souboru"

#: dialogs.py:947 dialogs.py:958
msgid "Title"
msgstr "Název"

#: dialogs.py:948 dialogs.py:959
msgid "Author"
msgstr "Autor"

#: dialogs.py:949 dialogs.py:960
msgid "Series"
msgstr "Série"

#: dialogs.py:950 dialogs.py:961
msgid "Custom"
msgstr "Vlastní"

#: dialogs.py:953
msgid "Background"
msgstr "Pozadí"

#: dialogs.py:954
msgid "Border"
msgstr "Ohraničení"

#: dialogs.py:974
msgid "Fonts:"
msgstr "Písma:"

#: dialogs.py:983
msgid ""
"Select a font and specify a size in pixels.\n"
"If font set to 'Default', uses the tweak value from\n"
"'generate_cover_title_font' if present."
msgstr ""
"Vyberte písmo a zadejte velikost v pixelech.\n"
"Pokud je písmo nastaveno na „Default“, použije se hodnota\n"
"vylepšení „generate_cover_title_font“, pokud existuje."

#: dialogs.py:1002
msgid "Use the same font family for all text"
msgstr "Použít stejnou rodinu písem pro všechen text"

#: dialogs.py:1003
msgid ""
"When checked, the same font family is used for all text content on the cover"
msgstr ""
"Pokud je zaškrtnuto, pro veškerý textový obsah na obálce se použije stejná "
"rodina písem"

#: dialogs.py:1010
msgid "Auto-reduce font size to fit on one line"
msgstr "Automaticky zmenšit písmo, aby se vešlo na jeden řádek"

#: dialogs.py:1011
msgid ""
"When checked, the font size will be used as a maximum size.\n"
"A reduced size will be used where needed to fit text on one line."
msgstr ""
"Pokud je zaškrtnuto, velikost písma se použije jako maximální velikost.\n"
"Kde je potřeba vměstnat text na jeden řádek, použije se menší velikost."

#: dialogs.py:1017
msgid "Colors:"
msgstr "Barvy:"

#: dialogs.py:1035
msgid "Reset %s color"
msgstr "Obnovit barvu %s"

#: dialogs.py:1041
msgid "Select a %s color"
msgstr "Vybrat barvu %s"

#: dialogs.py:1063
msgid "Reset %s fill color"
msgstr "Obnovit barvu výplně pro %s"

#: dialogs.py:1069
msgid "Select %s fill color"
msgstr "Vybrat barvu výplně pro %s"

#: dialogs.py:1080
msgid "Use the same fill color for all text"
msgstr "Použít stejnou barvu výplně pro všechen text"

#: dialogs.py:1081
msgid ""
"When checked, the fill color is used for all text.\n"
"When unchecked, you can set different fill colors for each text type."
msgstr ""
"Pokud je zaškrtnuto, barva výplně se použije pro všechen text.\n"
"Pokud zaškrtnuto není, můžete pro jednotlivé typy textu nastavit různé barvy výplně."

#: dialogs.py:1092
msgid "Left aligned"
msgstr "Zarovnáno vlevo"

#: dialogs.py:1094
msgid "Centered"
msgstr "Na střed"

#: dialogs.py:1096
msgid "Right aligned"
msgstr "Zarovnáno vpravo"

#: dialogs.py:1207
msgid "Size:"
msgstr "Velikost:"

#: dialogs.py:1211
msgid "Cover width:"
msgstr "Šířka obálky:"

#: dialogs.py:1212
msgid "The width in pixels of the output .jpg file"
msgstr "Šířka výstupního souboru .jpg v pixelech"

#: dialogs.py:1218
msgid "Cover height:"
msgstr "Výška obálky:"

#: dialogs.py:1219
msgid "The height in pixels of the output .jpg file"
msgstr "Výška výstupního souboru .jpg v pixelech"

#: dialogs.py:1225
msgid "Stretch image to use as cover background"
msgstr "Roztáhnout obrázek a použít ho jako pozadí obálky"

#: dialogs.py:1226
msgid ""
"Check this to overlay text on the image background.\n"
"Uncheck this to place text around the image."
msgstr ""
"Zaškrtněte, pokud chcete text překrýt přes obrázek na pozadí.\n"
"Zrušte zaškrtnutí, pokud chcete text umístit kolem obrázku."

#: dialogs.py:1230
msgid "Resize cover dimensions to match background image"
msgstr "Změnit rozměry obálky podle obrázku na pozadí"

#: dialogs.py:1231
msgid ""
"Check this to automatically resize the cover based on\n"
"the dimensions of the currently chosen background image"
msgstr ""
"Zaškrtněte, pokud chcete automaticky změnit velikost obálky\n"
"podle rozměrů aktuálně vybraného obrázku na pozadí"

#: dialogs.py:1235
msgid "Resize image to scale up if smaller than available area"
msgstr "Zvětšit obrázek, pokud je menší než dostupná oblast"

#: dialogs.py:1236
msgid ""
"Check this to automatically resize the cover image to fit the\n"
"the maximum area available if it is too small"
msgstr ""
"Zaškrtněte, pokud chcete automaticky zvětšit obrázek obálky tak,\n"
"aby se vešel do maximální dostupné oblasti, pokud je příliš malý"

#: dialogs.py:1242
msgid "Margins:"
msgstr "Okraje:"

#: dialogs.py:1247
msgid "Top margin:"
msgstr "Horní okraj:"

#: dialogs.py:1248
msgid ""
"The margin in pixels from the top of the cover\n"
"to the first content"
msgstr ""
"Okraj v pixelech od horního okraje obálky\n"
"k prvnímu obsahu"

#: dialogs.py:1256
msgid "Bottom margin:"
msgstr "Dolní okraj:"

#: dialogs.py:1257
msgid ""
"The margin in pixels from the bottom of the cover\n"
"to the last content"
msgstr ""
"Okraj v pixelech od dolního okraje obálky\n"
"k poslednímu obsahu"

#: dialogs.py:1265
msgid "Left margin:"
msgstr "Levý okraj:"

#: dialogs.py:1266
msgid ""
"The minimum margin in pixels from the left of the cover\n"
"to the text content"
msgstr ""
"Minimální okraj v pixelech od levého okraje obálky\n"
"k textovému obsahu"

#: dialogs.py:1274
msgid "Right margin:"
msgstr "Pravý okraj:"

#: dialogs.py:1275
msgid ""
"The minimum margin in pixels from the right of the cover\n"
"to the text content"
msgstr ""
"Minimální okraj v pixelech od pravého okraje obálky\n"
"k textovému obsahu"

#: dialogs.py:1283
msgid "Text padding:"
msgstr "Odsazení textu:"

#: dialogs.py:1284
msgid "The spacing in pixels between successive lines of text"
msgstr "Mezera v pixelech mezi po sobě jdoucími řádky textu"

#: dialogs.py:1291
msgid "Image padding:"
msgstr "Odsazení obrázku:"

#: dialogs.py:1292
msgid ""
"The spacing in pixels between the image and text\n"
"placed above and below it"
msgstr ""
"Mezera v pixelech mezi obrázkem a textem\n"
"umístěným nad ním a pod ním"

#: dialogs.py:1302
msgid "Border Widths:"
msgstr "Šířky ohraničení:"

#: dialogs.py:1306
msgid "Cover border:"
msgstr "Ohraničení obálky:"

#: dialogs.py:1307
msgid ""
"The width in pixels of a border around the edge\n"
"of the cover. Specify 0 for no border"
msgstr ""
"Šířka ohraničení kolem okraje obálky v pixelech.\n"
"Pokud ohraničení nechcete, zadejte 0"

#: dialogs.py:1314
msgid "Image border:"
msgstr "Ohraničení obrázku:"

#: dialogs.py:1315
msgid ""
"The width in pixels of a border around the edge\n"
"of the image. Specify 0 for no border"
msgstr ""
"Šířka ohraničení kolem okraje obrázku v pixelech.\n"
"Pokud ohraničení nechcete, zadejte 0"

#: dialogs.py:1354
msgid "Field Order:"
msgstr "Pořadí polí:"

#: dialogs.py:1355
msgid ""
"Alter the order of items on the cover and\n"
"whether they are displayed using the checkbox"
msgstr ""
"Změňte pořadí položek na obálce a pomocí\n"
"zaškrtávacího políčka určete, zda se mají zobrazit"

#: dialogs.py:1369
msgid "Move field up"
msgstr "Přesunout pole nahoru"

#: dialogs.py:1376
msgid "Move field down"
msgstr "Přesunout pole dolů"

#: dialogs.py:1382
msgid "Other Options:"
msgstr "Další volby:"

#: dialogs.py:1386
msgid "Custom text:"
msgstr "Vlastní text:"

#: dialogs.py:1396
msgid "Swap author LN,FN to FN LN"
msgstr "Prohodit autora z Příjmení, Jméno na Jméno Příjmení"

#: dialogs.py:1397
msgid ""
"Use this option if your authors are stored as LN, FN\n"
"but you prefer to see FN LN on the book cover"
msgstr ""
"Tuto volbu použijte, pokud jsou autoři uloženi jako Příjmení, Jméno,\n"
"ale na obálce knihy je chcete zobrazit jako Jméno Příjmení"

#: dialogs.py:1401
msgid "Series text:"
msgstr "Text série:"

#: dialogs.py:1402
msgid ""
"Change the way series information is displayed.\n"
"Useful for non-English languages!"
msgstr ""
"Změňte způsob zobrazení informací o sérii.\n"
"Užitečné pro jiné jazyky než angličtinu."

#: dialogs.py:1410
msgid "Metadata: (*not saved)"
msgstr "Metadata: (*neukládá se)"

#: dialogs.py:1411
msgid ""
"Optionally override the text in these fields for this book.\n"
"These are not saved as part of the settings profile.\n"
"This functionality is disabled if multiple books are selected."
msgstr ""
"Volitelně můžete přepsat text v těchto polích pro tuto knihu.\n"
"Tyto hodnoty se neukládají jako součást profilu nastavení.\n"
"Tato funkce je zakázána, pokud je vybráno více knih."

