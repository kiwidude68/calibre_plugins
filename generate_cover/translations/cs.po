#: dialogs.py:808
msgid "File exists"
msgstr "Soubor existuje"

#: dialogs.py:809
msgid "An image already exists with this name."
msgstr "Obrázek s tímto názvem už existuje."

#: dialogs.py:814
msgid "Failed to rename image"
msgstr "Nepodařilo se přejmenovat obrázek"

#: dialogs.py:823
msgid "Add cover images"
msgstr "Přidat obrázky obálek"

#: dialogs.py:838
msgid "You cannot remove this image"
msgstr "Tento obrázek nelze odebrat"

#: dialogs.py:841
msgid "Are you sure you want to delete the image: %s"
msgstr "Opravdu chcete odstranit obrázek: %s"

#: dialogs.py:852 dialogs.py:910
msgid "Cannot write"
msgstr "Nelze zapisovat"

#: dialogs.py:853
