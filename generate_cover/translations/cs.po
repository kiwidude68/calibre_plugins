#: dialogs.py:745
msgid "Export completed"
msgstr "Export dokončen"

#: dialogs.py:746
msgid "Cover setting exported to<br>%s"
msgstr "Nastavení obálky exportováno do<br>%s"

#: dialogs.py:754
msgid "Select setting file(s) to import"
msgstr "Vyberte soubory nastavení k importu"

#: dialogs.py:755 dialogs.py:761
msgid "GC Files"
msgstr "Soubory Generate Cover"

#: dialogs.py:761
msgid "Save setting as"
msgstr "Uložit nastavení jako"

#: dialogs.py:788
msgid "You cannot rename this image"
msgstr "Tento obrázek nelze přejmenovat"

#: dialogs.py:790 dialogs.py:791
