msgid "Autosave settings"
msgstr "Automaticky ukládat nastavení"

#: dialogs.py:461
msgid ""
"Do not prompt to save changes to a setting. Always save when\n"
"switching to another setting, clicking OK or using Import/Export."
msgstr ""
"Neptat se na uložení změn nastavení. Vždy uložit při přepnutí\n"
"na jiné nastavení, kliknutí na OK nebo použití importu/exportu."

