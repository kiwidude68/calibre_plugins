msgstr "Zadaný název není jedinečný"

#: dialogs.py:594 dialogs.py:837
msgid "Cannot remove"
msgstr "Nelze odebrat"

#: dialogs.py:595
msgid "You cannot remove the default setting"
msgstr "Výchozí nastavení nelze odebrat"

#: dialogs.py:596 dialogs.py:840 dialogs.py:1574 dialogs.py:1593
msgid "Are you sure?"
msgstr "Opravdu?"

#: dialogs.py:597
msgid "Are you sure you want to remove the '%s' setting?"
msgstr "Opravdu chcete odebrat nastavení „%s“?"

#: dialogs.py:610 dialogs.py:787 dialogs.py:813
msgid "Cannot rename"
msgstr "Nelze přejmenovat"

#: dialogs.py:611
msgid "You cannot rename the default setting"
msgstr "Výchozí nastavení nelze přejmenovat"

#: dialogs.py:612 dialogs.py:613
msgid "New setting name:"
msgstr "Nový název nastavení:"

#: dialogs.py:621
msgid "Setting exists"
msgstr "Nastavení existuje"

#: dialogs.py:622
msgid "A saved setting already exists with this name."
msgstr "Uložené nastavení s tímto názvem už existuje."

#: dialogs.py:647
msgid "Import Failed"
msgstr "Import se nezdařil"

#: dialogs.py:648
msgid "This is not a valid Generate Cover export archive"
msgstr "Toto není platný exportní archiv Generate Cover"

#: dialogs.py:686
msgid "Cannot import"
msgstr "Nelze importovat"

#: dialogs.py:687 dialogs.py:879
msgid "Failed to copy image"
