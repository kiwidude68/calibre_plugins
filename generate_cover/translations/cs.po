#: action.py:90
msgid "Corrupted Configuration File"
msgstr "Poškozený konfigurační soubor"

#: action.py:91
msgid ""
"<p>Your configuration file was corrupted (see Details).</p>)<p>Please report"
" your exact recent actions which led to this on the MobileRead forum thread "
"for this plugin so it can be fixed.</p><p>The configuration has been fixed "
"automatically.</p>"
msgstr ""
"<p>Konfigurační soubor byl poškozen (viz Podrobnosti).</p><p>Nahlaste prosím"
" přesný postup posledních akcí, které k tomu vedly, ve vlákně fóra "
"MobileRead pro tento modul, aby bylo možné problém "
"opravit.</p><p>Konfigurace byla automaticky opravena.</p>"

